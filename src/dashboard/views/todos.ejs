<%- include('header', { title: 'Todo List', active: 'todos' }) %>
  <div class="page-header">
    <div class="icon">&#9744;</div>
    <h1>Todo List</h1>
  </div>

  <div class="path">
    <div class="top">
      <div class="text">
        <div class="name">Add New Item</div>
        <div class="description">Create a new todo item for this server.</div>
      </div>
      <div class="right-side">
        <form method="POST" action="/<%= guildId %>/todos/add" style="display:flex;gap:8px;align-items:center;">
          <input name="text" placeholder="What needs to be done?" required style="width:220px;">
          <button class="btn btn-primary">Add</button>
        </form>
      </div>
    </div>
  </div>

  <% if (items.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">&#9744;</div>
      <p>No todo items. Add one above.</p>
    </div>
  <% } else { %>
    <div class="path" style="padding:0;">
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Text</th>
              <th>Author</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% for (const item of items) { %>
              <tr>
                <td>#<%= item.id %></td>
                <td><%= item.text %></td>
                <td><%= item.authorTag || item.authorId %></td>
                <td style="white-space:nowrap;"><%= new Date(item.createdAt).toLocaleString() %></td>
                <td>
                  <form method="POST" action="/<%= guildId %>/todos/edit" style="display:inline-flex;gap:4px;">
                    <input type="hidden" name="id" value="<%= item.id %>">
                    <input name="text" value="<%= item.text %>" style="width:150px;" required>
                    <button class="btn btn-primary btn-sm">Edit</button>
                  </form>
                  <form method="POST" action="/<%= guildId %>/todos/remove" style="display:inline;">
                    <input type="hidden" name="id" value="<%= item.id %>">
                    <button class="btn btn-danger btn-sm" onclick="return confirm('Remove?')">Remove</button>
                  </form>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
<%- include('footer') %>
