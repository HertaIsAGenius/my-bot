<%- include('header', { title: 'Logging', active: 'logging' }) %>
  <div class="page-header">
    <div class="icon">&#9881;</div>
    <h1>Logging Configuration</h1>
  </div>

  <div class="path">
    <div class="top">
      <div class="text">
        <div class="name">Message Logging</div>
        <div class="description">Toggle message logging for this server.</div>
      </div>
      <div class="right-side">
        <% var cfg = logCfg[guildId]; %>
        <form method="POST" action="/<%= guildId %>/logging" id="msgForm">
          <input type="hidden" name="type" value="messages">
          <input type="hidden" name="enabled" value="<%= !(cfg && cfg.messages) %>">
          <div class="toggle <%= (cfg && cfg.messages) ? 'on' : '' %>" onclick="this.classList.toggle('on'); document.getElementById('msgForm').submit();">
            <div class="circle"></div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="path">
    <div class="top">
      <div class="text">
        <div class="name">Reaction Logging</div>
        <div class="description">Toggle reaction logging for this server.</div>
      </div>
      <div class="right-side">
        <% var cfg2 = logCfg[guildId]; %>
        <form method="POST" action="/<%= guildId %>/logging" id="reactionForm">
          <input type="hidden" name="type" value="reactions">
          <input type="hidden" name="enabled" value="<%= !(cfg2 && cfg2.reactions) %>">
          <div class="toggle <%= (cfg2 && cfg2.reactions) ? 'on' : '' %>" onclick="this.classList.toggle('on'); document.getElementById('reactionForm').submit();">
            <div class="circle"></div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="section-label">Per-Channel Logging</div>

  <% var chCfg = channelLogCfg; %>
  <% var chIds = Object.keys(chCfg); %>
  <% if (chIds.length === 0) { %>
    <div class="path">
      <div class="top">
        <div class="text">
          <div class="name">No channel overrides</div>
          <div class="description">No per-channel logging configured.</div>
        </div>
      </div>
    </div>
  <% } else { %>
    <% for (const chId of chIds) { %>
      <% var c = chCfg[chId]; %>
      <div class="path clickable">
        <div class="top">
          <div class="text">
            <div class="name">Channel <code style="font-size:12px;opacity:.6;"><%= chId %></code></div>
            <div class="description">Messages: <%= c.messages ? 'ON' : 'OFF' %> &middot; Reactions: <%= c.reactions ? 'ON' : 'OFF' %></div>
          </div>
          <div class="right-side">
            <span class="arrow">&#9654;</span>
          </div>
        </div>
        <div class="content">
          <form method="POST" action="/<%= guildId %>/logging" id="chMsgForm_<%= chId %>" style="display:inline;">
            <input type="hidden" name="channelId" value="<%= chId %>">
            <input type="hidden" name="type" value="messages">
            <input type="hidden" name="enabled" value="<%= !c.messages %>">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
              <span style="font-size:13px;color:var(--text-secondary);">Messages</span>
              <div class="toggle <%= c.messages ? 'on' : '' %>" onclick="this.classList.toggle('on'); document.getElementById('chMsgForm_<%= chId %>').submit();">
                <div class="circle"></div>
              </div>
            </div>
          </form>
          <form method="POST" action="/<%= guildId %>/logging" id="chReactForm_<%= chId %>" style="display:inline;">
            <input type="hidden" name="channelId" value="<%= chId %>">
            <input type="hidden" name="type" value="reactions">
            <input type="hidden" name="enabled" value="<%= !c.reactions %>">
            <div style="display:flex;align-items:center;gap:12px;">
              <span style="font-size:13px;color:var(--text-secondary);">Reactions</span>
              <div class="toggle <%= c.reactions ? 'on' : '' %>" onclick="this.classList.toggle('on'); document.getElementById('chReactForm_<%= chId %>').submit();">
                <div class="circle"></div>
              </div>
            </div>
          </form>
        </div>
      </div>
    <% } %>
  <% } %>
<%- include('footer') %>
