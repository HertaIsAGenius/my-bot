<%- include('header', { title: 'Mod Channel', active: 'modchannel' }) %>
  <div class="page-header">
    <div class="icon">&#128172;</div>
    <h1>Moderator Channel</h1>
  </div>

  <% var m = meta[guildId]; %>
  <div class="path">
    <div class="top">
      <div class="text">
        <div class="name">Current Channel</div>
        <div class="description">
          <% if (m && m.moderatorChannel) { %>
            Channel set to <code style="opacity:.6;"><%= m.moderatorChannel %></code>
          <% } else { %>
            No moderator channel configured for this server.
          <% } %>
        </div>
      </div>
      <div class="right-side">
        <% if (m && m.moderatorChannel) { %>
          <form method="POST" action="/<%= guildId %>/modchannel" onsubmit="return confirm('Remove configuration?')">
            <input type="hidden" name="channelId" value="">
            <button class="btn btn-danger btn-sm">Remove</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>

  <div class="section-label">Set Channel</div>

  <div class="path">
    <div class="top">
      <div class="text">
        <div class="name">New Channel</div>
        <div class="description">Enter a channel ID to set as the moderator channel.</div>
      </div>
      <div class="right-side">
        <form method="POST" action="/<%= guildId %>/modchannel" style="display:flex;gap:8px;align-items:center;">
          <input name="channelId" placeholder="e.g. 123456789012345678" required style="width:200px;">
          <button class="btn btn-primary">Save</button>
        </form>
      </div>
    </div>
  </div>
<%- include('footer') %>
