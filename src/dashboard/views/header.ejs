<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Dashboard' %> — ProbeBot</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="burger" onclick="toggleSidebar()" id="burgerBtn">
      <div class="line"></div>
      <div class="line"></div>
      <div class="line"></div>
    </div>
    <div class="branding">
      <div class="logo">P</div>
      <span>ProbeBot</span>
    </div>
    <% if (locals.guildId) { %>
      <div class="server-selector" onclick="toggleDropdown('serverDropdown')">
        <div class="icon">
          <% var g = (locals.guilds || []).find(x => x.id === guildId) %>
          <% if (g && g.icon) { %>
            <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.png" alt="">
          <% } else { %>
            <%= g ? g.name.charAt(0).toUpperCase() : '#' %>
          <% } %>
        </div>
        <span class="name"><%= g ? g.name : guildId %></span>
        <span class="arrow"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></span>
        <div class="dropdown server-dropdown" id="serverDropdown">
          <% for (const sg of (locals.guilds || [])) { %>
            <a href="/<%= sg.id %>/home" class="option">
              <div class="opt-icon">
                <% if (sg.icon) { %>
                  <img src="https://cdn.discordapp.com/icons/<%= sg.id %>/<%= sg.icon %>.png" alt="">
                <% } else { %>
                  <%= sg.name.charAt(0).toUpperCase() %>
                <% } %>
              </div>
              <span class="opt-name"><%= sg.name %></span>
            </a>
          <% } %>
        </div>
      </div>
    <% } %>
    <div class="spacer"></div>
    <% if (locals.user) { %>
      <div class="user" onclick="toggleDropdown('userDropdown')">
        <div class="avatar">
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="" onerror="this.style.display='none'">
        </div>
        <span class="username"><%= user.username %></span>
        <span class="arrow"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></span>
        <div class="dropdown user-dropdown-menu" id="userDropdown">
          <div class="dropdown-header">
            <span class="dropdown-username"><%= user.username %></span>
          </div>
          <div class="dropdown-divider"></div>
          <a href="/logout" class="dropdown-item">Log out</a>
        </div>
      </div>
    <% } %>
  </nav>

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <nav class="sidebar-nav">
        <div class="intro-line">
          <a href="/" class="home-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </a>
          <div style="flex:1;"></div>
        </div>
        <% var pages = [
          { id: 'dashboard', label: 'Dashboard', path: 'home', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>' },
          { id: 'infractions', label: 'Infractions', path: 'infractions', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>' },
          { id: 'tickets', label: 'Tickets', path: 'tickets', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>' },
        ]; %>
        <% var managementPages = [
          { id: 'todos', label: 'Todo List', path: 'todos', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 12 2 2 4-4"/></svg>' },
          { id: 'logging', label: 'Logging', path: 'logging', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.855z"/></svg>' },
          { id: 'slowmode', label: 'Slowmode', path: 'slowmode', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' },
          { id: 'modchannel', label: 'Mod Channel', path: 'modchannel', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>' },
        ]; %>
        <% if (locals.guildId) { %>
          <% for (const p of pages) { %>
            <a href="/<%= guildId %>/<%= p.path %>" class="sidebar-item <%= active === p.id ? 'selected' : '' %>">
              <span class="icon"><%- p.icon %></span>
              <span><%= p.label %></span>
              <div class="bar"></div>
            </a>
          <% } %>
          <div class="label">Management</div>
          <% for (const p of managementPages) { %>
            <a href="/<%= guildId %>/<%= p.path %>" class="sidebar-item <%= active === p.id ? 'selected' : '' %>">
              <span class="icon"><%- p.icon %></span>
              <span><%= p.label %></span>
              <div class="bar"></div>
            </a>
          <% } %>
        <% } %>
      </nav>
    </aside>
    <main class="content">
      <div class="content-inner">
